{
  "_comment": "Dexter Notification Config — copy to ~/.dexter/notifications.json and fill in your credentials",

  "channel": "none",

  "telegram": {
    "bot_token": "YOUR_TELEGRAM_BOT_TOKEN",
    "chat_id": "YOUR_TELEGRAM_CHAT_ID"
  },

  "whatsapp": {
    "api_url": "http://localhost:3000",
    "session": "dexter",
    "phone": "+1234567890"
  },

  "ycloud": {
    "api_key": "YOUR_YCLOUD_API_KEY",
    "from": "+1234567890",
    "to": "+1234567890"
  },

  "slack": {
    "webhook_url": "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"
  },

  "discord": {
    "webhook_url": "https://discord.com/api/webhooks/YOUR/WEBHOOK/URL"
  },

  "events": {
    "session_end": true,
    "workflow_complete": true,
    "audit_block": true,
    "error": true
  },

  "format": {
    "prefix": "🤖 Dexter",
    "max_length": 4000
  }
}
